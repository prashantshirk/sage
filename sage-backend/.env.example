# MongoDB Atlas connection string (free tier at mongodb.com)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/sage_db

# Groq API key (free at console.groq.com)
GROQ_API_KEY=gsk_...

# Google Gemini API key (free at aistudio.google.com)
GEMINI_API_KEY=AIza...

# Google OAuth credentials (from console.cloud.google.com)
# Enable: Gmail API, Google Calendar API, Google+ API
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/callback

# Random secret for JWT signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=

FLASK_ENV=development
FRONTEND_URL=http://localhost:3000
